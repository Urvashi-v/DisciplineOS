{
  "name": "disciplineos",
  "version": "1.0.0",
  "private": true,
  "description": "DisciplineOS — AI-Powered Discipline Operating System",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,mjs,cjs}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,mjs,cjs}\" --cache",
    "clean": "turbo run clean",
    "db:generate": "turbo run db:generate",
    "db:migrate": "pnpm --filter @disciplineos/db migrate:dev",
    "db:push": "pnpm --filter @disciplineos/db push",
    "db:seed": "pnpm --filter @disciplineos/db seed",
    "db:studio": "pnpm --filter @disciplineos/db studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "turbo": "^2.3.3",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
