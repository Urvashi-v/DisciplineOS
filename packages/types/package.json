{
  "name": "@disciplineos/types",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@disciplineos/config": "workspace:*",
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "catalog:"
  }
}
