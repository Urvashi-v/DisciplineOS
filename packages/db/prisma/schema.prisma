// DisciplineOS — Prisma schema
// -----------------------------------------------------------------------------
// Phase 0 lays the identity, billing and notification foundation. Feature
// domains (missions, commitments, scoring, gamification, social, AI reports) are
// added in their own migrations as those features are built, keeping each
// migration small and reviewable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums (foundation)
// -----------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  GITHUB
}

enum PlanTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum NotificationType {
  MISSION_REMINDER
  COMMITMENT_AT_RISK
  STREAK_MILESTONE
  COACH_INSIGHT
  CHALLENGE_UPDATE
  FRIEND_ACTIVITY
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
}

// -----------------------------------------------------------------------------
// Enums (missions)
// -----------------------------------------------------------------------------

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MissionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
  FAILED
  EXPIRED
}

enum FocusSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum CommitmentType {
  REFUNDABLE_DEPOSIT
  SOCIAL_ACCOUNTABILITY
  TIME_COMMITMENT
  PERSONAL_PROMISE
  STREAK_RISK
  CHARACTER_PROGRESS
  REWARD_LOCK
}

enum CommitmentStatus {
  PENDING
  ACTIVE
  FULFILLED
  FORFEITED
  RELEASED
}

enum StreakType {
  DAILY_FOCUS
  MISSION_COMPLETION
  CHALLENGE
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum ChallengeVisibility {
  PRIVATE
  PUBLIC
}

enum ChallengeStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED
}

// -----------------------------------------------------------------------------
// Identity
// -----------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  role          UserRole @default(USER)
  planTier      PlanTier @default(FREE)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile         Profile?
  accounts        Account[]
  sessions        Session[]
  subscription    Subscription?
  notifications   Notification[]
  missions        Mission[]
  focusSessions   FocusSession[]
  commitments     Commitment[]
  streaks         Streak[]
  friendships     Friendship[]  @relation("UserFriendships")
  friendOf        Friendship[]  @relation("FriendFriendships")
  challengeEntries ChallengeParticipant[]

  @@index([planTier])
  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  username    String   @unique
  avatarUrl   String?
  timezone    String   @default("UTC")
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

/// OAuth / social login accounts linked to a user.
model Account {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  createdAt         DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// Server-side session records (refresh-token rotation lives in Redis; this is
/// the durable audit/revocation record).
model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -----------------------------------------------------------------------------
// Billing
// -----------------------------------------------------------------------------

model Plan {
  id          String   @id @default(cuid())
  tier        PlanTier @unique
  name        String
  description String?
  priceCents  Int      @default(0)
  currency    String   @default("USD")
  features    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  externalCustomerId String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([status])
  @@map("subscriptions")
}

// -----------------------------------------------------------------------------
// Notifications
// -----------------------------------------------------------------------------

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// -----------------------------------------------------------------------------
// Missions
// -----------------------------------------------------------------------------

/// A commitment the user activates and focuses on — the core unit of the product.
model Mission {
  id              String        @id @default(cuid())
  userId          String
  title           String
  description     String?
  priority        Priority      @default(MEDIUM)
  status          MissionStatus @default(DRAFT)
  durationMinutes Int
  progress        Int           @default(0)
  tags            String[]      @default([])
  deadline        DateTime?
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusSessions FocusSession[]
  commitments   Commitment[]

  @@index([userId, status])
  @@index([userId, deadline])
  @@map("missions")
}

// -----------------------------------------------------------------------------
// Focus, commitments, streaks
// -----------------------------------------------------------------------------

/// A focus/deep-work block. Source of truth for focus hours and the heatmap.
model FocusSession {
  id            String             @id @default(cuid())
  userId        String
  missionId     String?
  status        FocusSessionStatus @default(ACTIVE)
  plannedMinutes Int               @default(25)
  actualSeconds Int                @default(0)
  interruptions Int                @default(0)
  startedAt     DateTime           @default(now())
  endedAt       DateTime?
  createdAt     DateTime           @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission? @relation(fields: [missionId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@map("focus_sessions")
}

/// A Commitment Vault contract — a stake attached to a goal/mission.
model Commitment {
  id              String           @id @default(cuid())
  userId          String
  missionId       String?
  title           String
  type            CommitmentType   @default(REFUNDABLE_DEPOSIT)
  status          CommitmentStatus @default(ACTIVE)
  stakeAmountCents Int?
  reward          String?
  completion      Int              @default(0)
  deadline        DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission? @relation(fields: [missionId], references: [id], onDelete: SetNull)

  @@index([userId, status])
  @@map("commitments")
}

model Streak {
  id             String     @id @default(cuid())
  userId         String
  type           StreakType @default(DAILY_FOCUS)
  current        Int        @default(0)
  longest        Int        @default(0)
  lastActiveDate DateTime?
  updatedAt      DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@map("streaks")
}

// -----------------------------------------------------------------------------
// Social
// -----------------------------------------------------------------------------

model Friendship {
  id        String           @id @default(cuid())
  userId    String
  friendId  String
  status    FriendshipStatus @default(ACCEPTED)
  createdAt DateTime         @default(now())

  user   User @relation("UserFriendships", fields: [userId], references: [id], onDelete: Cascade)
  friend User @relation("FriendFriendships", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
  @@index([userId])
  @@map("friendships")
}

model Challenge {
  id           String              @id @default(cuid())
  title        String
  description  String?
  visibility   ChallengeVisibility @default(PUBLIC)
  status       ChallengeStatus     @default(ACTIVE)
  totalDays    Int                 @default(7)
  currentDay   Int                 @default(1)
  startsAt     DateTime            @default(now())
  endsAt       DateTime?
  createdAt    DateTime            @default(now())

  participants ChallengeParticipant[]

  @@map("challenges")
}

model ChallengeParticipant {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  rank        Int?
  progress    Int      @default(0)
  joinedAt    DateTime @default(now())

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@map("challenge_participants")
}
