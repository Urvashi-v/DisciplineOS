// DisciplineOS — Prisma schema
// -----------------------------------------------------------------------------
// Phase 0 lays the identity, billing and notification foundation. Feature
// domains (missions, commitments, scoring, gamification, social, AI reports) are
// added in their own migrations as those features are built, keeping each
// migration small and reviewable.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Enums (foundation)
// -----------------------------------------------------------------------------

enum UserRole {
  USER
  ADMIN
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  GITHUB
}

enum PlanTier {
  FREE
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  EXPIRED
}

enum NotificationType {
  MISSION_REMINDER
  COMMITMENT_AT_RISK
  STREAK_MILESTONE
  COACH_INSIGHT
  CHALLENGE_UPDATE
  FRIEND_ACTIVITY
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  PUSH
  EMAIL
}

// -----------------------------------------------------------------------------
// Enums (missions)
// -----------------------------------------------------------------------------

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum MissionStatus {
  DRAFT
  SCHEDULED
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
  FAILED
  EXPIRED
}

// -----------------------------------------------------------------------------
// Identity
// -----------------------------------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String?
  role          UserRole @default(USER)
  planTier      PlanTier @default(FREE)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  profile       Profile?
  accounts      Account[]
  sessions      Session[]
  subscription  Subscription?
  notifications Notification[]
  missions      Mission[]

  @@index([planTier])
  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  displayName String
  username    String   @unique
  avatarUrl   String?
  timezone    String   @default("UTC")
  bio         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

/// OAuth / social login accounts linked to a user.
model Account {
  id                String       @id @default(cuid())
  userId            String
  provider          AuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  createdAt         DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

/// Server-side session records (refresh-token rotation lives in Redis; this is
/// the durable audit/revocation record).
model Session {
  id           String   @id @default(cuid())
  userId       String
  sessionToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// -----------------------------------------------------------------------------
// Billing
// -----------------------------------------------------------------------------

model Plan {
  id          String   @id @default(cuid())
  tier        PlanTier @unique
  name        String
  description String?
  priceCents  Int      @default(0)
  currency    String   @default("USD")
  features    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id                 String             @id @default(cuid())
  userId             String             @unique
  planId             String
  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  externalCustomerId String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([status])
  @@map("subscriptions")
}

// -----------------------------------------------------------------------------
// Notifications
// -----------------------------------------------------------------------------

model Notification {
  id        String              @id @default(cuid())
  userId    String
  type      NotificationType
  channel   NotificationChannel @default(IN_APP)
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// -----------------------------------------------------------------------------
// Missions
// -----------------------------------------------------------------------------

/// A commitment the user activates and focuses on — the core unit of the product.
model Mission {
  id              String        @id @default(cuid())
  userId          String
  title           String
  description     String?
  priority        Priority      @default(MEDIUM)
  status          MissionStatus @default(DRAFT)
  durationMinutes Int
  deadline        DateTime?
  scheduledFor    DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, deadline])
  @@map("missions")
}
