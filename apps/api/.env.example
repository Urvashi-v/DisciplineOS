NODE_ENV=development
PORT=4000

# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://disciplineos:disciplineos@localhost:5432/disciplineos?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# CORS origin for the web app
WEB_ORIGIN="http://localhost:3000"

# JWT secrets — REPLACE with strong random values in any non-local environment
JWT_ACCESS_SECRET="dev-access-secret-change-me-please-0001"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me-please-0002"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
